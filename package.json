{
  "name": "helpdesk",
  "private": true,
  "workspaces": ["core", "server", "client"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '@helpdesk/client' build && bun run --filter '@helpdesk/server' build",
    "start": "bun run --filter '@helpdesk/server' start",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2"
  },
  "dependencies": {
    "pg": "^8.22.0"
  }
}
